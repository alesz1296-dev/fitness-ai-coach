generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  username     String  @unique
  password     String
  firstName    String?
  lastName     String?
  age          Int?
  weight       Float?
  height       Float?
  sex          String? // male | female
  fitnessLevel String? // beginner | intermediate | advanced
  goal         String? // short description
  activityLevel String? // sedentary | light | moderate | active | very_active
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  goals            Goal[]
  workouts         Workout[]
  foods            FoodLog[]
  weights          WeightLog[]
  conversations    Conversation[]
  templates        WorkoutTemplate[]
  calorieGoals     CalorieGoal[]
  monthlyReports   MonthlyReport[]
}

// ─────────────────────────────────────────────
// GOALS (generic)
// ─────────────────────────────────────────────
model Goal {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // weight_loss | weight_gain | strength | endurance | custom
  target    Float
  current   Float    @default(0)
  unit      String
  startDate DateTime @default(now())
  endDate   DateTime?
  achieved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// CALORIE GOAL (nutrition-specific goal with projection)
// ─────────────────────────────────────────────
model CalorieGoal {
  id              Int      @id @default(autoincrement())
  userId          Int
  name            String   // e.g. "Summer Cut 2026"
  type            String   // cut | bulk | maintain
  currentWeight   Float
  targetWeight    Float
  targetDate      DateTime
  dailyCalories   Float    // calculated target kcal/day
  proteinGrams    Float
  carbsGrams      Float
  fatsGrams       Float
  weeklyChange    Float    // projected kg change per week
  tdee            Float?   // used for calculation reference
  active          Boolean  @default(true)
  aiGenerated     Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// ─────────────────────────────────────────────
// WORKOUTS
// ─────────────────────────────────────────────
model Workout {
  id             Int      @id @default(autoincrement())
  userId         Int
  name           String
  templateId     Int?     // which template this was based on (optional)
  date           DateTime @default(now())
  duration       Int      // minutes
  caloriesBurned Float?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([userId])
  @@index([date])
}

model WorkoutExercise {
  id           Int      @id @default(autoincrement())
  workoutId    Int
  exerciseName String
  sets         Int
  reps         Int
  weight       Float?
  rpe          Int?     // Rate of Perceived Exertion 1-10
  notes        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt   // allow inline edits

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseName])
}

// ─────────────────────────────────────────────
// WORKOUT TEMPLATES
// ─────────────────────────────────────────────
model WorkoutTemplate {
  id           Int      @id @default(autoincrement())
  userId       Int?     // null = system/recommended template
  name         String
  description  String?
  splitType    String   // PPL | Upper_Lower | Bro_Split | Full_Body | Custom
  objective    String   // hypertrophy | strength | fat_loss | endurance | general
  frequency    Int      // sessions per week: 2-6
  dayLabel     String   // e.g. "Day 1 - Chest & Triceps"
  muscleGroups String   // JSON array as string: '["chest","triceps"]'
  isSystem     Boolean  @default(false)  // pre-seeded by the app
  aiGenerated  Boolean  @default(false)  // created by AI coach
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises TemplateExercise[]

  @@index([userId])
  @@index([isSystem])
  @@index([splitType])
}

model TemplateExercise {
  id           Int      @id @default(autoincrement())
  templateId   Int
  exerciseName String
  sets         Int
  reps         String   // stored as string to allow ranges like "8-12"
  restSeconds  Int?
  notes        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ─────────────────────────────────────────────
// FOOD LOGS
// ─────────────────────────────────────────────
model FoodLog {
  id       Int      @id @default(autoincrement())
  userId   Int
  foodName String
  calories Float
  protein  Float?
  carbs    Float?
  fats     Float?
  quantity Float
  unit     String
  meal     String?  // breakfast | lunch | dinner | snack
  date     DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─────────────────────────────────────────────
// WEIGHT LOGS
// ─────────────────────────────────────────────
model WeightLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─────────────────────────────────────────────
// CONVERSATIONS (AI Chat)
// ─────────────────────────────────────────────
model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String   // user | assistant
  message   String
  response  String?
  agentType String   // coach | nutritionist | general
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentType])
}

// ─────────────────────────────────────────────
// MONTHLY REPORTS
// ─────────────────────────────────────────────
model MonthlyReport {
  id                  Int      @id @default(autoincrement())
  userId              Int
  month               Int      // 1–12
  year                Int
  workoutsCompleted   Int      @default(0)
  totalVolumeKg       Float?   // total weight moved (sets * reps * weight summed)
  avgDailyCalories    Float?
  avgDailyProtein     Float?
  weightStart         Float?
  weightEnd           Float?
  weightChange        Float?
  prsHit              Int      @default(0)
  goalProgress        Float?   // % toward active calorie goal
  aiSummary           String?  // AI-generated narrative summary
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
}
