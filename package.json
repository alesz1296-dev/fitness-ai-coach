{
  "name": "fitness-ai-coach",
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered fitness and nutrition coaching app",
  "main": "dist/server.js",
  "scripts": {
    "predev": "node scripts/kill-port.cjs",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint:client": "cd client && npm run lint"
  },
  "keywords": [
    "fitness",
    "ai",
    "coaching",
    "nutrition"
  ],
  "author": "alesz1296-dev",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "openai": "^4.24.1",
    "pg": "^8.13.3",
    "prisma": "^5.7.1",
    "rate-limit-redis": "^4.2.0",
    "tsx": "^4.7.0",
    "winston": "^3.11.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "expo": "~55.0.17",
    "ngrok": "^5.0.0-beta.2",
    "typescript": "^5.3.3"
  }
}
