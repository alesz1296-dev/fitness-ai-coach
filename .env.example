# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FitAI Coach
APP_VERSION=1.0.0
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local Docker:  postgresql://postgres:postgres@localhost:5432/fitai
# Prod (Render): postgresql://user:pass@host:5432/fitai?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fitai"

# For production with PostgreSQL, replace with:
# DATABASE_URL="postgresql://user:password@localhost:5432/fitai?schema=public"

# ── Auth Tokens ───────────────────────────────────────────────────────────────
# Access token: short-lived (15m recommended). Use 7d only if not using refresh tokens.
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRY=15m

# Refresh token: long-lived (30 days), enables silent re-auth
REFRESH_SECRET=change-me-to-a-different-long-random-string
REFRESH_EXPIRY_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI Coach, Nutritionist & General chat (uses gpt-4o-mini by default).
# Get your key at: https://platform.openai.com/api-keys
# Typical cost: ~$0.15 per 1M input tokens with gpt-4o-mini
OPENAI_API_KEY=sk-proj-...your-key-here...
#
# To generate strong JWT secrets run:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to your frontend URL (e.g. https://myapp.com)
CLIENT_URL=http://localhost:5173

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Leave blank in dev — reset/verify links are logged to the server console instead.
# For production use Gmail App Passwords, SendGrid, Mailgun, Resend, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=FitAI Coach <noreply@fitai.example.com>
