generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model User {
  id            Int     @id @default(autoincrement())
  email         String  @unique
  username      String  @unique
  password      String
  firstName     String?
  lastName      String?
  age           Int?
  weight        Float?
  height        Float?
  sex           String? // "male" | "female"
  activityLevel String? // "sedentary" | "light" | "moderate" | "active" | "very_active"
  fitnessLevel  String?
  goal                 String?
  profileComplete      Boolean  @default(false)
  proteinMultiplier    Float    @default(2.0)
  trainingDaysPerWeek  Int?     // 1–7
  trainingHoursPerDay  Float?   // hours per session, e.g. 1.0, 1.5
  injuries             String?  // JSON array of injury area strings, e.g. '["Lower Back","Knee"]'
  periodStart          String?  // ISO date of most recent period start (females only)
  cycleLength          Int?     // menstrual cycle length in days (default 28)
  waterTargetMl        Float    @default(2000) // daily water target in ml
  emailVerified        Boolean  @default(false)
  planAdjustmentMode   String   @default("suggest") // "suggest" | "confirm" | "auto"
  role                 String   @default("user")
  permissionFlags      String   @default("[]")
  coachVisibility      String   @default("{\"workouts\":true,\"nutrition\":true,\"weight\":true,\"goals\":true,\"mealPlans\":true,\"calendar\":true}")
  createdAt            DateTime @default(now())
  updatedAt       DateTime @updatedAt

  goals          Goal[]
  workouts       Workout[]
  foods          FoodLog[]
  weights        WeightLog[]
  conversations  Conversation[]
  agentMessages  AgentMessage[]
  calorieGoals   CalorieGoal[]
  reports        MonthlyReport[]
  templates      WorkoutTemplate[]
  weeklyPlans    WeeklyPlan[]
  waterLogs      WaterLog[]
  mealPlans      MealPlan[]
  calendarDays   WorkoutCalendarDay[]
  customFoods      CustomFood[]
  customExercises  CustomExercise[]
  weeklyReviews    WeeklyReview[]
  idempotencyRecords IdempotencyRecord[]
  coachLinksAsCoach CoachClientLink[] @relation("CoachLinksAsCoach")
  coachLinksAsClient CoachClientLink[] @relation("CoachLinksAsClient")
  coachInvites CoachInvite[] @relation("CoachInvitesAsCoach")
  coachInviteAcceptances CoachInvite[] @relation("CoachInvitesAsClient")
  proposalsCreated CoachProposal[] @relation("CoachProposalCreatedBy")
  proposalsReceived CoachProposal[] @relation("CoachProposalForClient")
  proposalCommentsAuthored CoachProposalComment[] @relation("CoachProposalCommentAuthor")
  coachLibraryFavorites CoachLibraryFavorite[]
  auditLogs AuditLog[] @relation("AuditActor")
  featureFlagsUpdated FeatureFlag[] @relation("FeatureFlagUpdatedBy")
  impersonationSessionsCreated ImpersonationSession[] @relation("ImpersonationActor")
  impersonationSessionsTargeted ImpersonationSession[] @relation("ImpersonationTarget")

  @@index([email])
}

model CoachClientLink {
  id        Int      @id @default(autoincrement())
  coachId   Int
  clientId  Int
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach  User @relation("CoachLinksAsCoach", fields: [coachId], references: [id], onDelete: Cascade)
  client User @relation("CoachLinksAsClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([coachId, clientId])
  @@index([coachId, status])
  @@index([clientId, status])
}

model CoachInvite {
  id             Int      @id @default(autoincrement())
  coachId        Int
  code           String   @unique
  status         String   @default("invited")
  expiresAt      DateTime
  usedByClientId Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  coach        User  @relation("CoachInvitesAsCoach", fields: [coachId], references: [id], onDelete: Cascade)
  usedByClient User? @relation("CoachInvitesAsClient", fields: [usedByClientId], references: [id], onDelete: SetNull)

  @@index([coachId, status])
}

model CoachProposal {
  id         Int      @id @default(autoincrement())
  coachId    Int
  clientId   Int
  type       String
  status     String   @default("pending")
  sourceId   Int
  payload    String?
  note       String?
  acceptedAt DateTime?
  rejectedAt DateTime?
  appliedId  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  coach  User @relation("CoachProposalCreatedBy", fields: [coachId], references: [id], onDelete: Cascade)
  client User @relation("CoachProposalForClient", fields: [clientId], references: [id], onDelete: Cascade)
  comments CoachProposalComment[] @relation("CoachProposalComments")

  @@index([clientId, status])
  @@index([coachId, status])
}

model CoachProposalComment {
  id            Int      @id @default(autoincrement())
  proposalId    Int
  authorUserId   Int
  body          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  proposal CoachProposal @relation("CoachProposalComments", fields: [proposalId], references: [id], onDelete: Cascade)
  author   User          @relation("CoachProposalCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([proposalId, createdAt])
  @@index([authorUserId, createdAt])
}

model WeeklyReview {
  id                  Int      @id @default(autoincrement())
  userId              Int
  weekStart           String
  weekEnd             String
  averageWeight       Float?
  calorieAdherence    Float?
  proteinAdherence    Float?
  workoutsCompleted   Int      @default(0)
  plannedWorkouts     Int?
  performanceTrend    String?
  planStatus          String
  recommendation      String
  recommendedAdjustment String?
  fatigue             Int?
  soreness            Int?
  hunger              Int?
  sleepQuality        Int?
  stress              Int?
  perceivedPerformance Int?
  coachNote           String?
  adjustmentStatus    String   @default("suggested")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model CoachLibraryFavorite {
  id        Int      @id @default(autoincrement())
  coachId   Int
  itemType  String   // "template" | "meal"
  sourceId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach User @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, itemType, sourceId])
  @@index([coachId, itemType])
}

model IdempotencyRecord {
  id                 Int      @id @default(autoincrement())
  userId             Int
  key                String
  method             String
  path               String
  requestHash        String
  status             String   @default("pending")
  responseStatus     Int?
  responseBody       String?
  responseContentType String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, method, path])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actorUserId  Int?
  actorRole    String
  action       String
  targetType   String?
  targetId     Int?
  targetUserId Int?
  metadata     String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([targetUserId, createdAt])
}

model FeatureFlag {
  id              Int      @id @default(autoincrement())
  key             String   @unique
  label           String
  description     String?
  enabled         Boolean  @default(false)
  updatedByUserId Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("FeatureFlagUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([enabled])
}

model ImpersonationSession {
  id            Int      @id @default(autoincrement())
  token         String   @unique
  actorUserId   Int
  targetUserId  Int
  status        String   @default("active")
  createdAt     DateTime @default(now())
  endedAt       DateTime?

  actor  User @relation("ImpersonationActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target User @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId, status])
  @@index([targetUserId, status])
}

// ── Goals ─────────────────────────────────────────────────────────────────────

model Goal {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  target    Float
  current   Float    @default(0)
  unit      String
  startDate DateTime @default(now())
  endDate   DateTime?
  achieved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Workouts ──────────────────────────────────────────────────────────────────

model Workout {
  id             Int      @id @default(autoincrement())
  userId         Int
  name           String
  date           DateTime @default(now())
  duration       Int
  caloriesBurned Float?
  notes          String?
  templateId     Int?
  trainingType   String?  // "strength" | "hypertrophy" | "endurance" | "cardio" | "mobility"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([userId])
  @@index([date])
}

model WorkoutExercise {
  id           Int      @id @default(autoincrement())
  workoutId    Int
  exerciseName String
  sets         Int
  reps         Int
  weight       Float?
  rpe          Int?
  notes        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseName])
}

// ── Templates ─────────────────────────────────────────────────────────────────

model WorkoutTemplate {
  id           Int      @id @default(autoincrement())
  userId       Int?     // null = system template
  name         String
  description  String?
  splitType    String   // "PPL" | "Upper_Lower" | "Bro_Split" | "Full_Body" | "Custom"
  objective    String   // "hypertrophy" | "strength" | "fat_loss" | "endurance" | "general"
  frequency    Int      // sessions per week
  dayLabel     String   // e.g. "Push Day", "Leg Day"
  muscleGroups String   @default("[]") // JSON array stored as string (SQLite)
  isSystem     Boolean  @default(false)
  aiGenerated  Boolean  @default(false)
  provenanceRole String @default("user")
  provenanceSourceUserId Int?
  sourceProposalId Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  exercises TemplateExercise[]

  @@index([userId])
  @@index([isSystem])
}

model TemplateExercise {
  id           Int      @id @default(autoincrement())
  templateId   Int
  exerciseName String
  sets         Int
  reps         String   // allows ranges like "8-12"
  restSeconds  Int?
  notes        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ── Food & Nutrition ──────────────────────────────────────────────────────────

model FoodLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  foodName    String
  calories    Float
  protein     Float?
  carbs       Float?
  fats        Float?
  quantity    Float
  unit        String
  meal        String?  // "breakfast" | "lunch" | "dinner" | "snack"
  isCheatMeal Boolean  @default(false)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ── Weight Logs ───────────────────────────────────────────────────────────────

model WeightLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ── Calorie Goals ─────────────────────────────────────────────────────────────

model CalorieGoal {
  id                  Int      @id @default(autoincrement())
  userId              Int
  name                String?
  type                String   // "cut" | "bulk" | "maintain"
  currentWeight       Float
  targetWeight        Float
  targetDate          DateTime
  dailyCalories       Float
  proteinGrams        Float
  carbsGrams          Float
  fatsGrams           Float
  weeklyChange        Float    // kg per week (negative = cut)
  tdee                Float
  active              Boolean  @default(true)
  feasible            Boolean  @default(true)
  warning             String?
  aiGenerated         Boolean  @default(false)
  provenanceRole      String   @default("user")
  provenanceSourceUserId Int?
  sourceProposalId    Int?
  notes               String?
  // Macro cycling — training day vs rest day targets
  macrosCycling       Boolean  @default(false)
  trainDayCalories    Float?
  trainDayProtein     Float?
  trainDayCarbs       Float?
  trainDayFats        Float?
  restDayCalories     Float?
  restDayProtein      Float?
  restDayCarbs        Float?
  restDayFats         Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

// ── Chat / AI ─────────────────────────────────────────────────────────────────

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  message   String
  response  String?
  agentType String
  metadata  String?  // JSON: { suggestedWorkout?, suggestedPlan?, suggestedMealPlan? }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentType])
}

// ── Monthly Reports ───────────────────────────────────────────────────────────

model MonthlyReport {
  id              Int      @id @default(autoincrement())
  userId          Int
  year            Int
  month           Int
  totalWorkouts   Int
  totalVolume     Float    @default(0)
  avgCalories     Float    @default(0)
  avgProtein      Float    @default(0)
  weightStart     Float?
  weightEnd       Float?
  weightDelta     Float?
  prsHit          Int      @default(0)
  goalProgress    Float?
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}

// ── Weekly Plan ───────────────────────────────────────────────────────────────

model WeeklyPlan {
  id        Int            @id @default(autoincrement())
  userId    Int
  weekStart DateTime       // always the Monday of that week (UTC midnight)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  days WeeklyPlanDay[]

  @@unique([userId, weekStart])
  @@index([userId])
}

model WeeklyPlanDay {
  id             Int       @id @default(autoincrement())
  planId         Int
  dayIndex       Int       // 0 = Monday … 6 = Sunday
  label          String    @default("Training")
  targetCalories Float?
  actualCalories Float?
  completed      Boolean   @default(false)
  completedAt    DateTime?
  workoutId      Int?      // optional link to a logged workout
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  plan WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, dayIndex])
  @@index([planId])
}

// ── Water Logs ────────────────────────────────────────────────────────────────

model WaterLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Float    // ml
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ── Meal Planner ──────────────────────────────────────────────────────────────

model MealPlan {
  id        Int           @id @default(autoincrement())
  userId    Int
  name      String
  weekStart String        // ISO date "YYYY-MM-DD" of the Monday for this plan
  durationWeeks Int       @default(1)
  provenanceRole String   @default("user")
  provenanceSourceUserId Int?
  sourceProposalId Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  days MealPlanDay[]

  @@index([userId])
}

model MealPlanDay {
  id        Int             @id @default(autoincrement())
  planId    Int
  dayIndex  Int             // 0 = Monday … 6 = Sunday
  notes     String?
  createdAt DateTime        @default(now())

  plan    MealPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  entries MealPlanEntry[]

  @@unique([planId, dayIndex])
  @@index([planId])
}

// ── Workout Calendar ──────────────────────────────────────────────────────────

model WorkoutCalendarDay {
  id           Int      @id @default(autoincrement())
  userId       Int
  date         String   // "YYYY-MM-DD"
  workoutName  String?  // e.g. "Push Day", "Leg Day"
  muscleGroups String?  // JSON array, e.g. '["Chest","Triceps"]'
  templateId   Int?     // optional link to source template
  isRestDay    Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ── User custom foods (personal food database per user) ───────────────────────

model CustomFood {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  calories    Float
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fats        Float    @default(0)
  defaultQty  Float    @default(100)
  defaultUnit String   @default("g")
  tags        String   @default("[]") // JSON array
  basedOnId   String?  // FoodItem.id if cloned from DB food (optional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

model CustomExercise {
  id               Int      @id @default(autoincrement())
  userId           Int
  name             String
  primaryMuscle    String
  secondaryMuscles String   @default("[]")
  equipment        String   @default("Bodyweight")
  difficulty       String   @default("beginner")
  instructions     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

// ── Food & Exercise Catalogue (seeded, read-only at runtime) ──────────────────

model FoodItem {
  id          String  @id          // e.g. "f001"
  name        String
  calories    Float
  protein     Float
  carbs       Float
  fats        Float
  defaultQty  Float
  defaultUnit String
  tags        String  @default("[]") // JSON array of tag strings
  aliases     String  @default("[]") // JSON array of search aliases
  localizedNames String @default("{}") // JSON map of locale → translated name

  @@index([name])
}

model ExerciseItem {
  id               String  @id          // e.g. "e001"
  name             String
  primaryMuscle    String
  secondaryMuscles String  @default("[]") // JSON array
  equipment        String
  difficulty       String  // "beginner" | "intermediate" | "advanced"
  instructions     String

  @@index([name])
  @@index([primaryMuscle])
  @@index([equipment])
}

model MealPlanEntry {
  id       Int    @id @default(autoincrement())
  dayId    Int
  meal     String // "breakfast" | "lunch" | "dinner" | "snack"
  foodName String
  calories Float
  protein  Float  @default(0)
  carbs    Float  @default(0)
  fats     Float  @default(0)
  quantity Float  @default(1)
  unit     String @default("serving")
  order    Int    @default(0)
  createdAt DateTime @default(now())

  day MealPlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

// ── Agent Conversation Memory ─────────────────────────────────────────────────
// One row per message (user or assistant), per agent thread.
// The agent loop reads the last 20 rows per (userId, agentType) at chat time.
// Trim-on-insert keeps the table bounded — oldest rows deleted after every save.
// This is separate from Conversation (which drives the chat UI history display).

model AgentMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  agentType String   // "coach" | "nutritionist" | "general"
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentType, createdAt])
}
